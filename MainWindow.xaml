<Window x:Class="autorun.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Менеджер автозагрузки" Height="600" Width="450"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen"
        Icon="icon.png"
        FontFamily="Segoe UI"
        AllowDrop="True" Drop="Window_Drop">

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="MainBorder" Storyboard.TargetProperty="Opacity"
                                     From="0" To="1" Duration="0:0:0.35">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="MainBorder" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                     From="20" To="0" Duration="0:0:0.4">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <Border x:Name="MainBorder" Background="{StaticResource WindowBackgroundBrush}" CornerRadius="12" BorderThickness="1" BorderBrush="#333" Opacity="0">
        <Border.RenderTransform>
            <TranslateTransform Y="20"/>
        </Border.RenderTransform>
        <Border.Effect>
            <DropShadowEffect BlurRadius="25" ShadowDepth="0" Opacity="0.4" Color="Black"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="50" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            
            <Grid Grid.Row="0" Background="Transparent" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0">
                    <Button Style="{StaticResource IconButtonStyle}" Click="AppIcon_Click" Margin="0,0,5,0" ToolTip="О программе">
                        <Image Source="icon.png" Width="20" Height="20" RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Button>
                    <TextBlock Text="МЕНЕДЖЕР АВТОЗАГРУЗКИ" Foreground="{StaticResource SecondaryTextBrush}" 
                               FontWeight="Bold" FontSize="12" VerticalAlignment="Center" Margin="5,0,0,0"/>
                </StackPanel>

                
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,10,0" VerticalAlignment="Center">
                    <Button Style="{StaticResource IconButtonStyle}" Click="Import_Click" ToolTip="Импорт настроек">
                        <TextBlock Text="↑" FontSize="16"/>
                    </Button>
                    <Button Style="{StaticResource IconButtonStyle}" Click="Export_Click" ToolTip="Экспорт настроек">
                        <TextBlock Text="↓" FontSize="16"/>
                    </Button>
                    <Button Style="{StaticResource IconButtonStyle}" Click="Refresh_Click" ToolTip="Обновить" x:Name="RefreshBtn">
                        <TextBlock Text="↻" FontSize="16" Margin="0,-2,0,0" x:Name="RefreshIcon" RenderTransformOrigin="0.5,0.5">
                            <TextBlock.RenderTransform>
                                <RotateTransform Angle="0"/>
                            </TextBlock.RenderTransform>
                        </TextBlock>
                    </Button>
                    <Button Style="{StaticResource IconButtonStyle}" Click="Close_Click" ToolTip="Закрыть">
                        <TextBlock Text="✕" FontSize="14" Margin="5,0,5,0"/>
                    </Button>
                </StackPanel>
            </Grid>
            
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="10,0,10,10">
                <StackPanel x:Name="ContentPanel">
                    
                    <StackPanel.Resources>
                        <DataTemplate x:Key="StartupItemTemplate">
                            <Border x:Name="CardBorder" CornerRadius="8" Margin="0,3,0,3" Padding="15,10" Cursor="Arrow">
                                <Border.Background>
                                    <SolidColorBrush Color="{StaticResource CardBackgroundColor}"/>
                                </Border.Background>
                                <Border.Triggers>
                                    <EventTrigger RoutedEvent="Border.Loaded">
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                 From="0" To="1" Duration="0:0:0.3">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseOut"/>
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                    <EventTrigger RoutedEvent="Border.MouseEnter">
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <ColorAnimation Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                                To="{StaticResource CardHoverColor}" Duration="0:0:0.15"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                    <EventTrigger RoutedEvent="Border.MouseLeave">
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <ColorAnimation Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                                To="{StaticResource CardBackgroundColor}" Duration="0:0:0.15"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Border.Triggers>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <Border Width="32" Height="32" CornerRadius="6" Background="#2A2D35" Grid.Column="0" Margin="0,0,12,0">
                                        <Image Source="{Binding IconSource}" Width="24" Height="24" HorizontalAlignment="Center" VerticalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality"/>
                                    </Border>
                                    
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold" FontSize="14"/>
                                        <TextBlock Text="{Binding Path}" Foreground="{StaticResource SecondaryTextBrush}" FontSize="10" Margin="0,3,0,0" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                    
                                    <CheckBox Grid.Column="2" IsChecked="{Binding IsEnabled}" Style="{StaticResource ToggleSwitchStyle}" VerticalAlignment="Center" Margin="10,0,10,0" Click="Toggle_Click" Tag="{Binding}"/>
                                    
                                    <Button Grid.Column="3" Style="{StaticResource IconButtonStyle}" Click="Delete_Click" Tag="{Binding}" VerticalAlignment="Center">
                                        <TextBlock Text="✕" FontSize="12"/>
                                    </Button>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </StackPanel.Resources>

                    <TextBlock Text="РЕЕСТР" Style="{StaticResource CategoryHeaderStyle}"
                               MouseLeftButtonDown="RegistryHeader_Click"
                               ToolTip="Клик — выключить/включить все"/>
                    <ItemsControl x:Name="RegistryList" ItemTemplate="{StaticResource StartupItemTemplate}" />
                    
                    <TextBlock Text="ПАПКА STARTUP" Style="{StaticResource CategoryHeaderStyle}"
                               MouseLeftButtonDown="FolderHeader_Click"
                               ToolTip="Клик — выключить/включить все"/>
                    <ItemsControl x:Name="StartupFolderList" ItemTemplate="{StaticResource StartupItemTemplate}" />
                    
                    <TextBlock Text="ПЛАНИРОВЩИК" Style="{StaticResource CategoryHeaderStyle}"
                               MouseLeftButtonDown="SchedulerHeader_Click"
                               ToolTip="Клик — выключить/включить все"/>
                    <ItemsControl x:Name="SchedulerList" ItemTemplate="{StaticResource StartupItemTemplate}" />
                    
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
